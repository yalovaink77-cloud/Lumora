generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                        String             @id
  name                      String
  email                     String
  emailVerified             Boolean            @default(false)
  image                     String?
  createdAt                 DateTime           @default(now())
  updatedAt                 DateTime           @updatedAt
  sessions                  Session[]
  accounts                  Account[]
  familyMemberships         FamilyMembership[]
  acceptedFamilyInvitations FamilyInvitation[] @relation("AcceptedFamilyInvitations")

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

enum FamilyMembershipRole {
  OWNER
  MEMBER
}

model Family {
  id             String             @id @default(cuid())
  displayName    String             @db.VarChar(100)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  memberships    FamilyMembership[]
  pregnancies    Pregnancy[]
  children       Child[]
  timelineEvents TimelineEvent[]
  invitations    FamilyInvitation[]

  @@map("family")
}

model FamilyMembership {
  id              String               @id @default(cuid())
  familyId        String
  userId          String
  role            FamilyMembershipRole
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  family          Family               @relation(fields: [familyId], references: [id], onDelete: Cascade)
  user            User                 @relation(fields: [userId], references: [id], onDelete: Restrict)
  sentInvitations FamilyInvitation[]   @relation("InvitationInviterMembership")

  @@unique([familyId, userId])
  @@unique([id, familyId])
  @@index([userId])
  @@map("family_membership")
}

model FamilyInvitation {
  id                    String               @id @default(cuid())
  familyId              String
  inviterMembershipId   String
  targetEmailNormalized String
  role                  FamilyMembershipRole
  secretHash            Bytes                @unique
  expiresAt             DateTime             @db.Timestamptz(3)
  consumedAt            DateTime?            @db.Timestamptz(3)
  acceptedByUserId      String?
  createdAt             DateTime             @default(now()) @db.Timestamptz(3)
  updatedAt             DateTime             @updatedAt @db.Timestamptz(3)
  family                Family               @relation(fields: [familyId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  inviterMembership     FamilyMembership     @relation("InvitationInviterMembership", fields: [inviterMembershipId, familyId], references: [id, familyId], onDelete: Restrict, onUpdate: Restrict)
  acceptedByUser        User?                @relation("AcceptedFamilyInvitations", fields: [acceptedByUserId], references: [id], onDelete: Restrict, onUpdate: Restrict)

  @@index([familyId])
  @@index([familyId, targetEmailNormalized, consumedAt, expiresAt])
  @@index([inviterMembershipId])
  @@map("family_invitation")
}

model Pregnancy {
  id             String          @id @default(cuid())
  familyId       String
  displayName    String          @db.VarChar(100)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  family         Family          @relation(fields: [familyId], references: [id], onDelete: Restrict)
  timelineEvents TimelineEvent[] @relation("PregnancyTimelineEvents")

  @@unique([id, familyId])
  @@index([familyId])
  @@map("pregnancy")
}

model Child {
  id             String          @id @default(cuid())
  familyId       String
  displayName    String          @db.VarChar(80)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  family         Family          @relation(fields: [familyId], references: [id], onDelete: Restrict)
  timelineEvents TimelineEvent[] @relation("ChildTimelineEvents")

  @@unique([id, familyId])
  @@index([familyId])
  @@map("child")
}

model TimelineEvent {
  id                String     @id @default(cuid())
  familyId          String
  pregnancyId       String?
  pregnancyFamilyId String?
  childId           String?
  childFamilyId     String?
  title             String     @db.VarChar(80)
  occurredAt        DateTime   @db.Timestamptz(3)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  family            Family     @relation(fields: [familyId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  pregnancy         Pregnancy? @relation("PregnancyTimelineEvents", fields: [pregnancyId, pregnancyFamilyId], references: [id, familyId], onDelete: Restrict, onUpdate: Restrict)
  child             Child?     @relation("ChildTimelineEvents", fields: [childId, childFamilyId], references: [id, familyId], onDelete: Restrict, onUpdate: Restrict)

  @@index([familyId, pregnancyId, occurredAt(sort: Desc), createdAt(sort: Desc), id(sort: Desc)])
  @@index([familyId, childId, occurredAt(sort: Desc), createdAt(sort: Desc), id(sort: Desc)])
  @@map("timeline_event")
}
