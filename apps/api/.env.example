PORT=3000
NODE_ENV=development
DATABASE_URL="postgresql://lumora:lumora@localhost:5432/lumora?schema=public"
BETTER_AUTH_SECRET="development-only-secret-minimum-32-characters-long"
BETTER_AUTH_URL="http://localhost:3000"
# Include lumora:// for the mobile app scheme. Add exp:// / exp://** only in
# non-production (development/test); production validation rejects Expo Go origins.
AUTH_TRUSTED_ORIGINS="http://localhost:3000,lumora://,exp://,exp://**"
AUTH_EMAIL_VERIFICATION_DELIVERY_MODE="capture"
AUTH_EMAIL_VERIFICATION_CONFIRMATION_PAGE_URL="http://localhost:3000/verify-email"
