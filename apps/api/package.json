{
  "name": "@lumora/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "start:prod": "node dist/main.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "pnpm run test:unit && pnpm run test:integration",
    "test:auth:postgres:runtime": "node --import tsx --test src/auth/auth.postgres.integration.ts",
    "test:family:postgres:runtime": "node --import tsx --test src/family/family.postgres.integration.ts",
    "test:pregnancy:postgres:runtime": "node --import tsx --test src/pregnancy/pregnancy.postgres.integration.ts",
    "test:child:postgres:runtime": "node --import tsx --test src/child/child.postgres.integration.ts",
    "test:unit": "node --import tsx --test --test-concurrency=1 $(find src -name '*.test.ts' ! -name '*.integration.test.ts' -print)",
    "test:integration": "node --import tsx --test --test-force-exit src/**/*.integration.test.ts"
  },
  "dependencies": {
    "@lumora/auth": "workspace:*",
    "@lumora/child": "workspace:*",
    "@lumora/database": "workspace:*",
    "@lumora/family": "workspace:*",
    "@lumora/pregnancy": "workspace:*",
    "better-auth": "1.6.23",
    "@nestjs/common": "^11.1.14",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.14",
    "@nestjs/platform-express": "^11.1.14",
    "express": "^5.2.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.14",
    "@types/express": "^5.0.6",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.65.0"
  }
}
