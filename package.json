{
  "name": "lumora",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.16.1",
  "engines": {
    "node": ">=24"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "test:auth:postgres": "node scripts/verify-auth-postgres.mjs",
    "test:family:postgres": "node scripts/verify-auth-postgres.mjs",
    "test:pregnancy:postgres": "node scripts/verify-auth-postgres.mjs",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prisma": "pnpm --filter @lumora/database exec prisma"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "eslint": "^10.7.0",
    "prettier": "^3.9.5",
    "prisma": "^6.19.2",
    "tsx": "^4.23.1",
    "turbo": "^2.10.5",
    "typescript": "^7.0.2"
  }
}
